  "capabilities": {
    "virtualWorkspaces": {
      "supported": "limited",
      "description": "File decorations are supported in virtual workspaces, but freshness sources may be limited when filesystem timestamps or Git/GitHub metadata are unavailable. Git history, export reports, and advanced caching are unavailable. Basic file information commands (copy date, show details) are supported when a trustworthy source exists."
    },
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/incredincomp/explorer-dates.git"
  },
  "bugs": {
    "url": "https://github.com/incredincomp/explorer-dates/issues"
  },
  "homepage": "https://github.com/incredincomp/explorer-dates#readme",
  "icon": "icons/explorer-dates.png",
  "scripts": {
    "lint": "eslint .",
    "test:critical": "npm run lint && npm run test:workflow-contracts && npm run test:freshness-policy-logging && npm run test:warning-filters && npm run test:config && npm run test:config-audit && npm run test:config-scenarios",
    "test:security-utils": "node -r ./tests/helpers/strictConsole.js tests/test-security-utils.js && node -r ./tests/helpers/strictConsole.js tests/test-security-allowed-paths-behavior.js",
    "test": "npm run test:suite",
    "test:suite": "npm run compile && npm run lint && npm run test:config && npm run test:config-scenarios && npm run test:feature-gates && npm run test:flows && npm run test:bundle && npm run test:verify-bundle && npm run test:extras && npm run test:performance",
    "test:config": "node -r ./tests/helpers/strictConsole.js tests/verify-config.js",
    "test:workflow-contracts": "node -r ./tests/helpers/strictConsole.js tests/test-workflow-script-contracts.js",
    "test:freshness-policy-logging": "node -r ./tests/helpers/strictConsole.js tests/test-freshness-policy-logging.js",
    "test:warning-filters": "node -r ./tests/helpers/strictConsole.js tests/test-warning-filters-scope.js",
    "test:web-config-event-contract": "node tests/test-web-config-event-contract.js",
    "test:dist-parity": "node scripts/check-dist-parity.js",
    "test:config-audit": "node -r ./tests/helpers/strictConsole.js tests/test-schema-audit.js",
    "test:config-scenarios": "node -r ./tests/helpers/strictConsole.js tests/test-configuration-scenarios.js",
    "test:feature-gates": "node -r ./tests/helpers/strictConsole.js tests/test-feature-gates.js",
    "test:flows": "node -r ./tests/helpers/strictConsole.js tests/exercise-flows.js",
    "test:bundle": "node -r ./tests/helpers/strictConsole.js tests/test-bundle.js",
		"test:verify-bundle": "node -r ./tests/helpers/strictConsole.js tests/verify-bundle.js && npm run test:chunk-exports",
		"test:chunk-exports": "node -r ./tests/helpers/strictConsole.js tests/verify-chunk-exports.js",
    "test:performance-baselines": "node -r ./tests/helpers/strictConsole.js tests/test-performance-baselines.js",
    "test:extras": "node -r ./tests/helpers/strictConsole.js scripts/run-test-suite.js",
    "test:contracts": "node -r ./tests/helpers/strictConsole.js tests/test-chunk-contracts.js && node -r ./tests/helpers/strictConsole.js tests/test-provider-contract.js",
    "test:fuzz-long": "node -r ./tests/helpers/strictConsole.js tests/test-advanced-cache-fuzz-long.js",
    "test:stress-crossplatform": "node -r ./tests/helpers/strictConsole.js tests/test-advanced-cache-crossplatform-stress.js",
    "test:performance": "node -r ./tests/helpers/strictConsole.js tests/test-performance-baselines.js && node -r ./tests/helpers/strictConsole.js tests/test-performance-mode.js && node -r ./tests/helpers/strictConsole.js tests/test-performance-under-load.js && node -r ./tests/helpers/strictConsole.js tests/test-performance-regression.js",
    "test:memory-suite": "node scripts/run-memory-suite.js",
    "test:memory-profiles": "node scripts/run-memory-profiles.js",
    "generate-locales": "node scripts/generate-locales.js",
    "compile": "npm run generate-locales && node esbuild-federation.js --chunks && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "vscode:prepublish": "npm run package-bundle",
    "package": "vsce package",
    "package-bundle": "npm run generate-locales && node esbuild-federation.js --production --chunks && node esbuild.js --production",
    "package-chunks": "npm run generate-locales && node esbuild-federation.js --production --chunks",
    "watch-chunks": "node esbuild-federation.js --watch --chunks",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.2.1",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.3.0",
    "npm-run-all": "^4.1.5"
  },
  "overrides": {
    "diff": ">=8.0.3",
    "serialize-javascript": ">=7.0.3"
  }
}
