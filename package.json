{
  "name": "explorer-dates",
  "displayName": "Explorer Dates",
  "description": "See file modification dates right in VS Code Explorer with intuitive time badges",
  "publisher": "incredincomp",
  "license": "SEE LICENSE IN LICENSE",
  "version": "1.3.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "file dates",
    "explorer decorations",
    "last modified",
    "file info",
    "explorer enhancement"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "browser": "./dist/extension.web.js",
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "contributes": {
    "commands": [
      {
        "command": "explorerDates.refreshDateDecorations",
        "title": "Refresh Date Decorations",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.showMetrics",
        "title": "Show Performance Metrics",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.openLogs",
        "title": "Open Logs",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.runWebDiagnostics",
        "title": "Run Web Diagnostics",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.showCurrentConfig",
        "title": "Show Current Configuration",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.resetToDefaults",
        "title": "Reset to Default Settings",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.migrateSettings",
        "title": "Migrate Settings",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.organizeSettings",
        "title": "Organize Settings",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.validateConfiguration",
        "title": "Validate Configuration",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.cleanLegacySettings",
        "title": "Clean Legacy Settings",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.showMigrationHistory",
        "title": "Show Migration History",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.exportConfiguration",
        "title": "Export Configuration",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.clearTelemetryData",
        "title": "Clear Telemetry Data",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.applyCustomColors",
        "title": "Apply Custom Colors",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.toggleDecorations",
        "title": "Toggle Date Decorations",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.copyFileDate",
        "title": "Copy File Date",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.showFileDetails",
        "title": "Show File Details",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.toggleFadeOldFiles",
        "title": "Toggle Fade Old Files",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.showFileHistory",
        "title": "Show File History",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.compareWithPrevious",
        "title": "Compare with Previous Version",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.showWorkspaceActivity",
        "title": "Show Workspace File Activity",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.showPerformanceAnalytics",
        "title": "Show Performance Analytics",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.showChunkStatus",
        "title": "Show Chunk Status",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.optimizeBundle",
        "title": "Optimize Bundle Size",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.applyPreset",
        "title": "Apply Configuration Preset",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.suggestOptimalPreset",
        "title": "Suggest Optimal Configuration",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.configureRuntime",
        "title": "Configure Runtime Chunks",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.validateTeamConfig",
        "title": "Validate Team Configuration",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.showKeyboardShortcuts",
        "title": "Show Keyboard Shortcuts",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.showFeatureTour",
        "title": "Show Feature Tour",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.showQuickSetup",
        "title": "Show Quick Setup Wizard",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.showWhatsNew",
        "title": "What's New in Explorer Dates",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.openTemplateManager",
        "title": "Open Template Manager",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.saveTemplate",
        "title": "Save Current Configuration as Template",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.generateReport",
        "title": "Generate File Modification Report",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.showApiInfo",
        "title": "Show Extension API Information",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.debugCache",
        "title": "Debug Cache Performance",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.runDiagnostics",
        "title": "Run Diagnostics (Fix Missing Decorations)",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.quickFix",
        "title": "Quick Fix Common Issues",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.testDecorations",
        "title": "Test Decoration Provider",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.monitorDecorations",
        "title": "Monitor VS Code Decoration Requests",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.testVSCodeRendering",
        "title": "Test VS Code Decoration Rendering",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.previewConfiguration",
        "title": "Preview Configuration (Internal)",
        "category": "Explorer Dates"
      },
      {
        "command": "explorerDates.clearPreview",
        "title": "Clear Configuration Preview (Internal)",
        "category": "Explorer Dates"
      }
    ],
    "keybindings": [
      {
        "command": "explorerDates.toggleDecorations",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "explorerViewletVisible"
      },
      {
        "command": "explorerDates.copyFileDate",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "explorerViewletFocus && !explorerResourceIsFolder"
      },
      {
        "command": "explorerDates.showFileDetails",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "explorerViewletFocus && !explorerResourceIsFolder"
      },
      {
        "command": "explorerDates.refreshDateDecorations",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "explorerViewletVisible"
      },
      {
        "command": "explorerDates.showWorkspaceActivity",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "workspaceFolderCount > 0 && explorerDates.analysisCommandsAvailable"
      },
      {
        "command": "explorerDates.toggleFadeOldFiles",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "explorerViewletVisible"
      },
      {
        "command": "explorerDates.openTemplateManager",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "workspaceFolderCount > 0 && explorerDates.workspaceTemplatesAvailable"
      },
      {
        "command": "explorerDates.generateReport",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "workspaceFolderCount > 0 && explorerDates.exportReportingAvailable"
      },
      {
        "command": "explorerDates.debugCache",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "explorerViewletVisible && explorerDates.analysisCommandsAvailable"
      },
      {
        "command": "explorerDates.runDiagnostics",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h",
        "when": "explorerViewletVisible && explorerDates.analysisCommandsAvailable"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "explorerDates.copyFileDate",
          "when": "!explorerResourceIsFolder && config.explorerDates.enableContextMenu",
          "group": "7_modification@1"
        },
        {
          "command": "explorerDates.showFileDetails",
          "when": "!explorerResourceIsFolder && config.explorerDates.enableContextMenu",
          "group": "7_modification@2"
        },
        {
          "command": "explorerDates.showFileHistory",
          "when": "!explorerResourceIsFolder && config.explorerDates.enableContextMenu && explorerDates.gitCommandsAvailable && resourceScheme == 'file'",
          "group": "7_modification@3"
        },
        {
          "command": "explorerDates.compareWithPrevious",
          "when": "!explorerResourceIsFolder && config.explorerDates.enableContextMenu && explorerDates.gitCommandsAvailable && resourceScheme == 'file'",
          "group": "7_modification@4"
        }
      ],
      "commandPalette": [
        {
          "command": "explorerDates.showWorkspaceActivity",
          "when": "workspaceFolderCount > 0 && explorerDates.analysisCommandsAvailable"
        },
        {
          "command": "explorerDates.showPerformanceAnalytics",
          "when": "workspaceFolderCount > 0 && explorerDates.analysisCommandsAvailable"
        },
        {
          "command": "explorerDates.debugCache",
          "when": "explorerDates.analysisCommandsAvailable && !explorerDates.isWeb"
        },
        {
          "command": "explorerDates.runDiagnostics",
          "when": "explorerDates.analysisCommandsAvailable && !explorerDates.isWeb"
        },
        {
          "command": "explorerDates.testDecorations",
          "when": "explorerDates.analysisCommandsAvailable && !explorerDates.isWeb"
        },
        {
          "command": "explorerDates.monitorDecorations",
          "when": "explorerDates.analysisCommandsAvailable && !explorerDates.isWeb"
        },
        {
          "command": "explorerDates.testVSCodeRendering",
          "when": "explorerDates.analysisCommandsAvailable && !explorerDates.isWeb"
        },
        {
          "command": "explorerDates.quickFix",
          "when": "explorerDates.analysisCommandsAvailable && !explorerDates.isWeb"
        },
        {
          "command": "explorerDates.migrateSettings",
          "when": "explorerDates.isWorkspaceTrusted"
        },
        {
          "command": "explorerDates.organizeSettings",
          "when": "explorerDates.isWorkspaceTrusted"
        },
        {
          "command": "explorerDates.resetToDefaults",
          "when": "explorerDates.isWorkspaceTrusted"
        },
        {
          "command": "explorerDates.cleanLegacySettings",
          "when": "explorerDates.isWorkspaceTrusted"
        },
        {
          "command": "explorerDates.applyCustomColors",
          "when": "explorerDates.isWorkspaceTrusted"
        },
        {
          "command": "explorerDates.openTemplateManager",
          "when": "workspaceFolderCount > 0 && explorerDates.workspaceTemplatesAvailable"
        },
        {
          "command": "explorerDates.saveTemplate",
          "when": "workspaceFolderCount > 0 && explorerDates.workspaceTemplatesAvailable && explorerDates.isWorkspaceTrusted"
        },
        {
          "command": "explorerDates.generateReport",
          "when": "workspaceFolderCount > 0 && explorerDates.exportReportingAvailable && explorerDates.isWorkspaceTrusted"
        },
        {
          "command": "explorerDates.showApiInfo",
          "when": "explorerDates.extensionApiAvailable"
        },
        {
          "command": "explorerDates.applyPreset",
          "when": "explorerDates.runtimeCommandsAvailable && explorerDates.isWorkspaceTrusted"
        },
        {
          "command": "explorerDates.suggestOptimalPreset",
          "when": "explorerDates.runtimeCommandsAvailable"
        },
        {
          "command": "explorerDates.configureRuntime",
          "when": "explorerDates.runtimeCommandsAvailable"
        },
        {
          "command": "explorerDates.showChunkStatus",
          "when": "explorerDates.runtimeCommandsAvailable"
        },
        {
          "command": "explorerDates.optimizeBundle",
          "when": "explorerDates.runtimeCommandsAvailable"
        },
        {
          "command": "explorerDates.validateTeamConfig",
          "when": "explorerDates.runtimeCommandsAvailable && explorerDates.isWorkspaceTrusted"
        },
        {
          "command": "explorerDates.exportConfiguration",
          "when": "explorerDates.isWorkspaceTrusted"
        },
        {
          "command": "explorerDates.clearTelemetryData",
          "when": "explorerDates.isWorkspaceTrusted"
        },
        {
          "command": "explorerDates.copyFileDate",
          "when": "false"
        },
        {
          "command": "explorerDates.showFileHistory",
          "when": "explorerDates.gitCommandsAvailable && resourceScheme == 'file'"
        },
        {
          "command": "explorerDates.compareWithPrevious",
          "when": "explorerDates.gitCommandsAvailable && resourceScheme == 'file'"
        },
        {
          "command": "explorerDates.previewConfiguration",
          "when": "false"
        },
        {
          "command": "explorerDates.clearPreview",
          "when": "false"
        },
        {
          "command": "explorerDates.runWebDiagnostics",
          "when": "explorerDates.isWeb"
        }
      ]
    },
    "colors": [
      {
        "id": "explorerDates.customColor.veryRecent",
        "description": "Custom color for files modified within 1 hour",
        "defaults": {
          "dark": "#00ff00",
          "light": "#00aa00",
          "highContrast": "#00ff00"
        }
      },
      {
        "id": "explorerDates.customColor.recent",
        "description": "Custom color for files modified within 1 day",
        "defaults": {
          "dark": "#ffff00",
          "light": "#cc9900",
          "highContrast": "#ffff00"
        }
      },
      {
        "id": "explorerDates.customColor.old",
        "description": "Custom color for files modified more than 1 day ago",
        "defaults": {
          "dark": "#ff0000",
          "light": "#cc0000",
          "highContrast": "#ff0000"
        }
      }
    ],
    "configuration": {
      "title": "Explorer Dates",
      "properties": {
        "explorerDates.showDateDecorations": {
          "type": "boolean",
          "default": true,
          "description": "Show last modified dates as decorations in the Explorer",
          "scope": "window"
        },
        "explorerDates.dateDecorationFormat": {
          "type": "string",
          "enum": [
            "smart",
            "relative-short",
            "relative-long",
            "absolute-short",
            "absolute-long"
          ],
          "default": "smart",
          "description": "Format for date decorations in Explorer",
          "enumDescriptions": [
            "Smart format: relative for recent (5m, 2h), absolute for older (truncated to 2 chars)",
            "Always relative with 2-char format (5m, 2h, 3d, 1w)",
            "Always relative - Note: truncated to 2 chars due to VS Code limits",
            "Always absolute - Note: truncated to 2 chars (Oc, Se, etc.)",
            "Always absolute with year - Note: truncated to 2 chars due to VS Code limits"
          ],
          "scope": "window"
        },
        "explorerDates.excludedFolders": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "node_modules",
            ".git",
            "dist",
            "build",
            "out",
            ".vscode-test"
          ],
          "description": "Folders to exclude from date decorations for better performance",
          "scope": "window"
        },
        "explorerDates.excludedPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.tmp",
            "**/*.log",
            "**/.git/**",
            "**/node_modules/**"
          ],
          "description": "File patterns (glob) to exclude from date decorations",
          "scope": "window"
        },
        "explorerDates.enableLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable detailed logging for debugging purposes",
          "scope": "window"
        },
        "explorerDates.locale": {
          "type": "string",
          "enum": [
            "en",
            "es",
            "fr",
            "de",
            "ja",
            "zh",
            "auto"
          ],
          "default": "auto",
          "description": "Language for date formatting (auto uses VS Code's display language)",
          "enumDescriptions": [
            "English",
            "Spanish",
            "French",
            "German",
            "Japanese",
            "Chinese",
            "Automatically detect from VS Code"
          ],
          "scope": "window"
        },
        "explorerDates.highContrastMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable high-contrast styling for decorations",
          "scope": "window"
        },
        "explorerDates.cacheTimeout": {
          "type": "number",
          "default": 30000,
          "minimum": 5000,
          "maximum": 300000,
          "description": "Cache timeout in milliseconds (5000-300000)",
          "scope": "window"
        },
        "explorerDates.maxCacheSize": {
          "type": "number",
          "default": 10000,
          "minimum": 100,
          "maximum": 50000,
          "description": "Maximum number of cached file decorations",
          "scope": "window"
        },
        "explorerDates.colorScheme": {
          "type": "string",
          "enum": [
            "none",
            "recency",
            "file-type",
            "subtle",
            "vibrant",
            "custom"
          ],
          "default": "none",
          "description": "Color scheme for date decorations",
          "enumDescriptions": [
            "No color coding",
            "Color by file age (green: recent, yellow: medium, red: old)",
            "Color by file type (different colors for different extensions)",
            "Subtle color variations",
            "Vibrant colors for better visibility",
            "Use custom color configuration"
          ],
          "scope": "window"
        },
        "explorerDates.freshnessSourcePolicy": {
          "type": "string",
          "enum": [
            "auto",
            "fs",
            "git",
            "github",
            "unknown"
          ],
          "default": "auto",
          "description": "Preferred freshness source policy (auto follows source ladder)",
          "enumDescriptions": [
            "Use the source ladder (FS -> Git -> GitHub -> Unknown)",
            "Use filesystem timestamps only",
            "Use Git-derived timestamps when available",
            "Use GitHub commit timestamps when available",
            "Always treat freshness as unknown"
          ],
          "scope": "window"
        },
        "explorerDates.freshnessShowUnknown": {
          "type": "boolean",
          "default": true,
          "description": "Show unknown freshness badges when no trustworthy source is available",
          "scope": "window"
        },
        "explorerDates.freshnessAllowVirtualFs": {
          "type": "boolean",
          "default": false,
          "description": "Allow filesystem timestamps for non-file (virtual) URI schemes when trusted",
          "scope": "window"
        },
        "explorerDates.freshnessTooltipVerbosity": {
          "type": "string",
          "enum": [
            "full",
            "compact"
          ],
          "default": "full",
          "description": "Verbosity of freshness tooltip details",
          "scope": "window"
        },
        "explorerDates.badge.sourceLabelMode": {
          "type": "string",
          "enum": [
            "auto",
            "always",
            "never"
          ],
          "default": "auto",
          "description": "Controls when the freshness source is shown in the tooltip (badges are age-only due to VS Code's 2-character badge limit)",
          "enumDescriptions": [
            "Show source in tooltip only for non-normal cases (non-filesystem or low confidence)",
            "Always show source in tooltip when source is known",
            "Never show source in tooltip"
          ],
          "scope": "window"
        },
        "explorerDates.freshnessBucketMinutesNow": {
          "type": "number",
          "default": 60,
          "minimum": 1,
          "maximum": 240,
          "description": "Minutes threshold for the 'now' freshness bucket",
          "scope": "window"
        },
        "explorerDates.freshnessBucketHoursToday": {
          "type": "number",
          "default": 24,
          "minimum": 1,
          "maximum": 72,
          "description": "Hours threshold for the 'today' freshness bucket",
          "scope": "window"
        },
        "explorerDates.freshnessBucketDaysTwo": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 14,
          "description": "Days threshold for the '2d' freshness bucket",
          "scope": "window"
        },
        "explorerDates.freshnessBucketDaysWeek": {
          "type": "number",
          "default": 7,
          "minimum": 2,
          "maximum": 60,
          "description": "Days threshold for the '1w' freshness bucket",
          "scope": "window"
        },
        "explorerDates.customColors": {
          "type": "object",
          "default": {
            "veryRecent": "#00ff00",
            "recent": "#ffff00",
            "old": "#ff0000"
          },
          "markdownDescription": "Define custom colors for the 'custom' color scheme. To apply these colors, use the `Explorer Dates: Apply Custom Colors` command or manually add them to your `workbench.colorCustomizations` setting. [Learn more](https://code.visualstudio.com/api/references/theme-color)",
          "properties": {
            "veryRecent": {
              "type": "string",
              "default": "#00ff00",
              "description": "Color for files modified within 1 hour"
            },
            "recent": {
              "type": "string",
              "default": "#ffff00",
              "description": "Color for files modified within 1 day"
            },
            "old": {
              "type": "string",
              "default": "#ff0000",
              "description": "Color for files modified more than 1 day ago"
            }
          },
          "scope": "window"
        },
        "explorerDates.migrateLegacyCustomColorsOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Allow Explorer Dates to migrate legacy explorerDates.customColors into workbench.colorCustomizations during startup. Disabled by default to avoid changing editor color settings without explicit consent.",
          "scope": "window"
        },
        "explorerDates.fadeOldFiles": {
          "type": "boolean",
          "default": false,
          "description": "Fade decorations for files older than specified threshold",
          "scope": "window"
        },
        "explorerDates.fadeThreshold": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "maximum": 365,
          "description": "Days after which to fade file decorations (when fadeOldFiles is enabled)",
          "scope": "window"
        },
        "explorerDates.showFileSize": {
          "type": "boolean",
          "default": false,
          "description": "Show file size alongside modification date (e.g., '5m|~1K')",
          "scope": "window"
        },
        "explorerDates.fileSizeFormat": {
          "type": "string",
          "enum": [
            "auto",
            "bytes",
            "kb",
            "mb"
          ],
          "default": "auto",
          "description": "Format for file size display (auto = smart formatting)",
          "enumDescriptions": [
            "Automatically choose best format (~1K, ~3M)",
            "Always show in bytes (~1234B)",
            "Always show in kilobytes (~1.2K)",
            "Always show in megabytes (~1.2M)"
          ],
          "scope": "window"
        },
        "explorerDates.enableContextMenu": {
          "type": "boolean",
          "default": true,
          "description": "Add Explorer Dates options to file context menu",
          "scope": "window"
        },
        "explorerDates.showGitInfo": {
          "type": "string",
          "enum": [
            "none",
            "author",
            "both"
          ],
          "default": "none",
          "description": "Show Git information alongside dates",
